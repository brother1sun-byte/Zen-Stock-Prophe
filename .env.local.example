# Copy this file to .env.local and paste your own J-Quants token.
# Keep .env.local private. It is ignored by git.

# Recommended for current J-Quants V2: API key from the dashboard.
JQUANTS_API_KEY=

# Legacy V1 options. Use only if your J-Quants account still uses V1 token auth.
# JQUANTS_REFRESH_TOKEN=
# JQUANTS_ID_TOKEN=
