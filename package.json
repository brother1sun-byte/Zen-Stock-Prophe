{
  "name": "japan-stock-prophet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -k \"npm:dev\" \"npm:backend\"",
    "backend": "cd backend && python main.py",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:guards": "node scripts/guard_no_backend_direct.js && node scripts/guard_no_rewrites.js && node scripts/guard_text_first.js",
    "restart": "powershell -ExecutionPolicy Bypass -File .\\scripts\\restart.ps1",
    "healthcheck": "powershell -ExecutionPolicy Bypass -File .\\scripts\\healthcheck.ps1",
    "verify:all": "npm run lint:guards && npm run healthcheck",
    "test": "echo No tests implemented && exit 0",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "test:all": "npm run build && npm run lint && npm run typecheck && npm run test:e2e",
    "smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke.ps1",
    "up": "powershell -ExecutionPolicy Bypass -File ./scripts/up.ps1",
    "down": "powershell -ExecutionPolicy Bypass -File ./scripts/stop.ps1",
    "diagnosis": "powershell -ExecutionPolicy Bypass -File ./scripts/diagnosis.ps1"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.5",
    "next-pwa": "^5.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}