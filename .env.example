# Zen Stock Prophet Pro local configuration
# Copy to .env for local use. Do not commit real secrets.

ZEN_API_HOST=0.0.0.0
ZEN_API_PORT=8889
ZEN_DB_PATH=./zen_stock_prophet.db
ZEN_CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Optional read-only market data integrations.
# Leave blank when not configured; the app will score only available inputs.
EDINET_API_KEY=
JQUANTS_API_KEY=
JQUANTS_ID_TOKEN=
JQUANTS_REFRESH_TOKEN=
JQUANTS_FREE_PLAN_DELAY_DAYS=84
JQUANTS_OFFICIAL_HISTORY_DAYS=730

# JPX universe screening. 0 means scan the full loaded domestic universe.
ZEN_JPX_UNIVERSE_PATH=
ZEN_JPX_LISTED_ISSUES_URL=https://www.jpx.co.jp/english/markets/statistics-equities/misc/tvdivq0000001vg2-att/data_e.xls
ZEN_JPX_UPDATED_ISSUES_URL=https://www.jpx.co.jp/english/markets/statistics-equities/misc/tvdivq0000001vg2-att/jyoujyou(updated)_e.xlsx
ZEN_SCREEN_MAX_UNIVERSE=0
ZEN_SCREEN_BATCH_SIZE=80

# Frontend
# Leave blank to use the current browser host, which supports phones on the same LAN.
VITE_ZEN_API_BASE=
VITE_EDINET_API_KEY=
